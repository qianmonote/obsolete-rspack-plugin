{
  "name": "obsolete-rspack-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A Rspack plugin that generates a browser-side standalone script detecting browser compatibility based on Browserslist and prompts users to upgrade.",
  "keywords": [
    "rspack",
    "plugin",
    "obsolete",
    "obsolete-web",
    "obsolete-rspack-plugin",
    "browserslist"
  ],
  "main": "src/index.js",
  "files": [
    "src"
  ],
  "scripts": {
    "test": "jest",
    "dev:basic": "rspack serve -c examples/basic/rspack.config.js",
    "dev:custom-template": "rspack serve -c examples/custom-template/rspack.config.js",
    "dev:custom-browsers": "rspack serve -c examples/custom-browsers/rspack.config.js",
    "dev:styled-container": "rspack serve -c examples/styled-container/rspack.config.js",
    "dev:auto-hide": "rspack serve -c examples/auto-hide/rspack.config.js",
    "build:examples": "rspack build -c examples/basic/rspack.config.js && rspack build -c examples/custom-template/rspack.config.js && rspack build -c examples/custom-browsers/rspack.config.js && rspack build -c examples/styled-container/rspack.config.js && rspack build -c examples/auto-hide/rspack.config.js"
  },
  "dependencies": {
    "browserslist": "^4.24.0",
    "obsolete-web": "^0.5.6"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.0"
  },
  "bugs": "https://github.com/qianmonote/obsolete-rspack-plugin/issues",
  "homepage": "https://github.com/qianmonote/obsolete-rspack-plugin",
  "repository": "https://github.com/qianmonote/obsolete-rspack-plugin.git",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.10",
    "@rspack/core": "^1.7.10",
    "glob": "^10.4.5",
    "jest": "^29.7.0"
  }
}
